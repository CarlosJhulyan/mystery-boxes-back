            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/orders/me", "host": ["{{base_url}}"], "path": ["orders", "me"] }
          }
        },
        {
          "name": "Obtener orden por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["orders", "{{order_id}}"] }
          }
