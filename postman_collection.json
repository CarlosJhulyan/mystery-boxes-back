{
  "info": {
    "name": "Mystery Box Peru API",
    "description": "Colección completa de endpoints para la API de Mystery Box Peru. Incluye auth automático y variables globales.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string", "description": "JWT del usuario — se guarda automáticamente al hacer login" },
    { "key": "admin_token", "value": "", "type": "string", "description": "JWT del admin — se guarda automáticamente al hacer login como admin" },
    { "key": "box_id", "value": "", "type": "string", "description": "Se llena automáticamente al crear una caja" },
    { "key": "order_id", "value": "", "type": "string", "description": "Se llena automáticamente al crear una orden" },
    { "key": "coupon_id", "value": "", "type": "string", "description": "Se llena automáticamente al crear un cupón" },
    { "key": "user_id", "value": "", "type": "string", "description": "Se llena automáticamente al registrarse" },
    { "key": "payment_id", "value": "12345678", "type": "string", "description": "ID de pago de MercadoPago para pruebas" }
  ],
  "item": [
    {
      "name": "👤 Users",
      "item": [
        {
          "name": "Registrar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('user_id', res.id);",
                  "  console.log('user_id guardado:', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Pérez\",\n  \"email\": \"juan@ejemplo.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/register", "host": ["{{base_url}}"], "path": ["users", "register"] }
          }
        },
        {
          "name": "Login usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.collectionVariables.set('user_id', res.user.id);",
                  "  console.log('token guardado');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@gmail.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/login", "host": ["{{base_url}}"], "path": ["users", "login"] }
          }
        },
        {
          "name": "Login ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('admin_token', res.token);",
                  "  console.log('admin_token guardado');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mysterybox.pe\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/login", "host": ["{{base_url}}"], "path": ["users", "login"] }
          }
        },
        {
          "name": "Mi perfil",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "Actualizar perfil",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Pérez Actualizado\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "Cambiar contraseña",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"nuevaPassword123\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"] }
          }
        }
      ]
    },
    {
      "name": "📦 Boxes",
      "item": [
        {
          "name": "Listar todas las cajas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/boxes", "host": ["{{base_url}}"], "path": ["boxes"] }
          }
        },
        {
          "name": "Filtrar por tema (Gaming)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/boxes?theme=Gaming",
              "host": ["{{base_url}}"],
              "path": ["boxes"],
              "query": [{ "key": "theme", "value": "Gaming" }]
            }
          }
        },
        {
          "name": "Filtrar por rareza (Épico)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/boxes?rarity=Épico",
              "host": ["{{base_url}}"],
              "path": ["boxes"],
              "query": [{ "key": "rarity", "value": "Épico" }]
            }
          }
        },
        {
          "name": "Obtener caja por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/boxes/{{box_id}}", "host": ["{{base_url}}"], "path": ["boxes", "{{box_id}}"] }
          }
        },
        {
          "name": "Crear caja [ADMIN]",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('box_id', res.id);",
                  "  console.log('box_id guardado:', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Caja Test Postman\",\n  \"description\": \"Caja creada desde Postman para pruebas\",\n  \"price\": 99.90,\n  \"theme\": \"Gaming\",\n  \"rarity\": \"Raro\",\n  \"image_url\": \"https://images.unsplash.com/photo-1593305841991-05c297ba4575?w=400\"\n}"
            },
            "url": { "raw": "{{base_url}}/boxes", "host": ["{{base_url}}"], "path": ["boxes"] }
          }
        },
        {
          "name": "Actualizar caja [ADMIN]",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Caja Test Actualizada\",\n  \"price\": 149.90,\n  \"is_active\": true\n}"
            },
            "url": { "raw": "{{base_url}}/boxes/{{box_id}}", "host": ["{{base_url}}"], "path": ["boxes", "{{box_id}}"] }
          }
        },
        {
          "name": "Desactivar caja [ADMIN]",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/boxes/{{box_id}}", "host": ["{{base_url}}"], "path": ["boxes", "{{box_id}}"] }
          }
        }
      ]
    },
    {
      "name": "🛒 Orders",
      "item": [
        {
          "name": "Crear orden (usuario autenticado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('order_id', res.order.id);",
                  "  console.log('order_id guardado:', res.order.id);",
                  "  console.log('URL de pago (sandbox):', res.preference.sandbox_init_point);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"box_id\": \"{{box_id}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] }
          }
        },
        {
          "name": "Crear orden (guest checkout)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('order_id', res.order.id);",
                  "  console.log('order_id guardado:', res.order.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guest_email\": \"invitado@correo.com\",\n  \"items\": [\n    { \"box_id\": \"{{box_id}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] }
          }
        },
        {
          "name": "Crear orden con cupón",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"box_id\": \"{{box_id}}\", \"quantity\": 1 }\n  ],\n  \"coupon_code\": \"BIENVENIDO20\"\n}"
            },
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] }
          }
        },
        {
          "name": "Mis órdenes",
